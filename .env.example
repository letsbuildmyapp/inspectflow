# InspectFlow client env. None of these are secrets.
# By default the app runs with VITE_USE_MOCK=true (localStorage backend) so it
# works offline. Switch to the Firebase emulator with VITE_USE_MOCK=false +
# VITE_USE_EMULATOR=true.

VITE_USE_MOCK=true
VITE_USE_EMULATOR=false

# Real Firebase config (only fill in once Alex has created the project)
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=inspectflow-demo
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# Optional: explicit Cloud Function origin (otherwise we hit the emulator)
# VITE_FUNCTIONS_URL=https://us-central1-inspectflow-demo.cloudfunctions.net
